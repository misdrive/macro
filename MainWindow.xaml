<Window x:Class="NeonProject.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Meow V1" Height="450" Width="800" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" KeyDown="Window_KeyDown"
        Topmost="True">
    <Window.Resources>
        <Storyboard x:Key="IntroAnimation">
            <DoubleAnimation Storyboard.TargetName="HelloText" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5" />
            <DoubleAnimation Storyboard.TargetName="HelloText" Storyboard.TargetProperty="(Canvas.Top)" From="200" To="80" Duration="0:0:1.2" BeginTime="0:0:0.5">
                <DoubleAnimation.EasingFunction><QuadraticEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="HelloText" Storyboard.TargetProperty="Opacity" From="1" To="0" Duration="0:0:0.8" BeginTime="0:0:1.0" />
            <DoubleAnimation Storyboard.TargetName="MainContent" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:1" BeginTime="0:0:1.5" />
        </Storyboard>
        <Style x:Key="NeonButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#f799f0"/>
            <Setter Property="BorderBrush" Value="#f799f0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="BtnBorder" Property="BorderBrush" Value="White"/><Setter Property="Foreground" Value="White"/><Setter TargetName="BtnBorder" Property="Background" Value="#15f799f0"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="NeonTextBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="#f799f0"/><Setter Property="BorderBrush" Value="#f799f0"/><Setter Property="CaretBrush" Value="White"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox"><Border x:Name="TxtBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10"><ScrollViewer x:Name="PART_ContentHost"/></Border></ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Window.Triggers><EventTrigger RoutedEvent="Window.Loaded"><BeginStoryboard Storyboard="{StaticResource IntroAnimation}"/></EventTrigger></Window.Triggers>
    <Grid Margin="20">
        <Border Background="#050505" CornerRadius="45" BorderBrush="#f799f0" BorderThickness="3"><Border.Effect><DropShadowEffect Color="#f799f0" BlurRadius="30" ShadowDepth="0" Opacity="0.8"/></Border.Effect></Border>
        <Canvas x:Name="IntroCanvas" ClipToBounds="True"><TextBlock x:Name="HelloText" Text="Meow V1" Foreground="#f799f0" FontSize="60" FontWeight="Bold" Canvas.Left="275" Canvas.Top="200" Opacity="0"/></Canvas>
        <Border CornerRadius="45" ClipToBounds="True">
            <Grid x:Name="MainContent" Opacity="0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="200"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="#f799f0" BorderThickness="0,0,1,0" Margin="10,40,0,40">
                    <StackPanel VerticalAlignment="Center">
                        <Button Content="UPGRADER" Margin="15,8" Height="45" Style="{StaticResource NeonButtonStyle}" Click="RunAutomation"/>
                        <Button Content="CRAFTER" Margin="15,8" Height="45" Style="{StaticResource NeonButtonStyle}" Click="RunAutomation"/>
                        <Button Content="GUNS RECYCLE" Margin="15,8" Height="45" Style="{StaticResource NeonButtonStyle}" Click="RunAutomation"/>
                        <Button Content="ITEM RECYCLE" Margin="15,8" Height="45" Style="{StaticResource NeonButtonStyle}" Click="RunAutomation"/>
                    </StackPanel>
                </Border>
                <Button Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="35" Width="30" Height="30" Click="CloseApp" Style="{StaticResource NeonButtonStyle}" Content="X" FontWeight="Bold"/>
                <Grid Grid.Column="1">
                    <StackPanel x:Name="WelcomePanel" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="MEOW V1" Foreground="#f799f0" FontSize="42" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="StatusLabel" Text="SYSTEMS OPERATIONAL" Foreground="#f799f0" FontSize="11" Opacity="0.5" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                        <Button Content="SETTINGS" Width="120" Height="35" Margin="0,40,0,0" Style="{StaticResource NeonButtonStyle}" Click="OpenSettings"/>
                    </StackPanel>
                    <StackPanel x:Name="SettingsPanel" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="SETTINGS" Foreground="#f799f0" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8"><TextBlock Text="STOP KEY" Foreground="#f799f0" VerticalAlignment="Center" Width="100" FontSize="14"/><Button x:Name="StopKeyBtn" Content="None" Width="120" Height="35" Style="{StaticResource NeonButtonStyle}" Click="StartKeyCapture"/></StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8"><TextBlock Text="RUNS" Foreground="#f799f0" VerticalAlignment="Center" Width="100" FontSize="14"/><TextBox x:Name="RunCountInput" Text="1" Width="120" Height="35" Style="{StaticResource NeonTextBoxStyle}"/></StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8"><TextBlock Text="INFINITE" Foreground="#f799f0" VerticalAlignment="Center" Width="100" FontSize="14"><TextBlock.Effect><DropShadowEffect BlurRadius="5" Color="#f799f0" ShadowDepth="0"/></TextBlock.Effect></TextBlock>
                            <CheckBox x:Name="InfiniteCheck" VerticalAlignment="Center"><CheckBox.Template><ControlTemplate TargetType="CheckBox"><Border x:Name="Box" Width="120" Height="35" BorderBrush="#f799f0" BorderThickness="1" CornerRadius="10" Background="Transparent" Cursor="Hand"><TextBlock x:Name="CheckIcon" Text="X" Foreground="#f799f0" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18" FontWeight="Bold"/></Border><ControlTemplate.Triggers><Trigger Property="IsChecked" Value="True"><Setter TargetName="CheckIcon" Property="Visibility" Value="Visible"/><Setter TargetName="Box" Property="Background" Value="#25f799f0"/></Trigger></ControlTemplate.Triggers></ControlTemplate></CheckBox.Template></CheckBox>
                        </StackPanel>
                        <Button Content="BACK" Width="100" Height="35" Margin="0,25,0,0" Style="{StaticResource NeonButtonStyle}" Click="CloseSettings"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>